{
	# Global options
	email admin@pumpboard.dev
}

pumpboard.dev, www.pumpboard.dev {
	# API and admin routes → backend
	handle /api/* {
		reverse_proxy backend:8000
	}

	handle /admin* {
		reverse_proxy backend:8000
	}

	handle /uploads/* {
		reverse_proxy backend:8000
	}

	# Everything else → Next.js frontend
	handle {
		reverse_proxy frontend:3000
	}
}
