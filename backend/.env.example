# Optional: GitHub personal access token for higher rate limits (5000/hr vs 60/hr)
GITHUB_TOKEN=

# Comma-separated list of allowed frontend origins
# Set to * to allow all, or specify your frontend URL(s)
CORS_ORIGINS=*

# Admin key — required to access /admin and to add/delete developers
# Pick any strong password or generate one: openssl rand -hex 16
ADMIN_KEY=
